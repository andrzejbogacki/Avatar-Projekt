node_modules/
logs/

# Pliki binarne efemeryd — dostarczane/pobierane poza wersjonowaniem (zależność zewnętrzna)
backend/modules/qac/ephemeris/*
!backend/modules/qac/ephemeris/README.md

# Lokalna konfiguracja narzędzia (Claude Code) — nie jest treścią projektu
.claude/settings.local.json

# media/ — odłożone (2026-07-08): zdjęcia + nagrania audio ~84 MB,
# decyzja o docelowym miejscu przechowywania (repo/LFS/chmura) w toku
media/

# Profile wygenerowane przez serwer podglądu — dane robocze, nie treść repo
backend/modules/qac/profiles/*.json

# Paczki backupu udostępniane do pobrania przez dev_server.js — nie treść repo
backend/dev_public/pobierz/
