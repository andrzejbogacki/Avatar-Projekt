# Pliki binarne efemeryd — dostarczane/pobierane poza wersjonowaniem (zależność zewnętrzna)
backend/modules/qac/ephemeris/*
!backend/modules/qac/ephemeris/README.md

# Lokalna konfiguracja narzędzia (Claude Code) — nie jest treścią projektu
.claude/settings.local.json

# media/ — odłożone (2026-07-08): zdjęcia + nagrania audio ~84 MB,
# decyzja o docelowym miejscu przechowywania (repo/LFS/chmura) w toku
media/

# Profile wygenerowane przez serwer podglądu — dane robocze, nie treść repo
backend/modules/qac/profiles/*.json

# Paczki backupu udostępniane do pobrania przez dev_server.js — nie treść repo
backend/dev_public/pobierz/

# Dane modułu Auth — sekrety (hashe haseł, tokeny aktywacji), nigdy do repo
backend/modules/auth/accounts/
backend/modules/auth/zaproszenia/

# Dane modułu PS — profile Protokołu Suwerenności (dane osobiste), nigdy do repo
backend/modules/ps/profile/

# Dane modułu Wymiennik — definicje tokenów, salda, transakcje, oferty
backend/modules/wymiennik/tokeny/
backend/modules/wymiennik/salda/
backend/modules/wymiennik/transakcje/
backend/modules/wymiennik/oferty/

# Dane modułu Rezonator — rekordy Źródeł
backend/modules/rezonator/zrodla/*.json

# Dane modułu Glosariusz — propozycje zmian (indeks/formy.json JEST wersjonowany — ADR-006)
backend/modules/glosariusz/propozycje/
